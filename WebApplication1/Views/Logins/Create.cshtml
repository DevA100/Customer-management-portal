@{
    ViewData["Title"] = "Create UserPage";
}

@*<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://docs.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
    </div>*@

<div class="col-md-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 style="padding:0px!important">Create User</h4>
        </div>
    </div>
</div>

<div class="col-md-6 grid-margin">
    <div class="card">
        <div class="card-body">

            <div class="form-group">
                <label>StaffEmail</label><br />
                <input type="text" class="form-control" id="staffemail" name="staffemail" placeholder="Enter staffemail" required />
            </div>

            @*AcctNo*@
            <div class="form-group">
                <label>Password</label>
                <input type="text" class="form-control" id="Password" name="Password" placeholder="Enter Password" required />

            </div>

            <div class="form-group">
                <label>Staff Name</label>
                <input type="text" class="form-control" id="staffName" name="staffName" placeholder="Enter staffName" required />

            </div>

            <div class="form-group">
                <label>Select Branch</label>
                <select class="form-control" id="branch" name="branch" required>

                    <option value=""></option>
                    <option value="AdeolaHopewell">AdeolaHopewell</option>
                    <option value="Camp">Camp</option>
                    <option value="Ogba">Ogba</option>
                    <option value="OkoOba">OkoOba</option>
                    <option value="Abuja">Abuja</option>
                    <option value="PHC">Port Harcourt</option>
                </select>

            </div>

            <button type="submit" class="btn btn-primary mr-2" id="btnRegisterUser">Submit</button>
            <button type="submit" class="btn btn-primary mr-2" id="showUserList">User List</button>

        </div>
    </div>
</div>

<div id="userList" class="col-md-6 grid-margin stretch-card" style="display:none">
    <div class="card">
        <div class="card-body">
            <div class="form-group" style="overflow:auto" id="UserListRecord">
                <table id="userListDatatable" class="table table-striped table-borderless">
                    <thead> <tr><th>Staff Email</th><th>Name</th></tr> </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<!-- Modal -->
<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog">

        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                @* <button type="button" class="close" data-dismiss="modal">&times;</button>*@
                <h4 class="modal-title">Update User</h4>
            </div>
            <div class="modal-body">
                @*email*@
                <div class="form-group">
                    <label>Staff Email</label>
                    <input type="text" class="form-control" id="sEmail" name="sEmail" />

                </div>


                @*staff name*@
                <div class="form-group">
                    <label>Staff Name</label>
                    <input type="text" class="form-control" id="sName" name="sName" />

                </div>

                <div class="form-group">
                    <label>Lock/Unlock User</label>
                    <select class="form-control" id="LockUser" required>

                        <option value=""></option>
                        <option value="0">Lock user</option>
                        <option value="1">Unlock user</option>
                    </select>

                </div>



                <button type="submit" class="btn btn-primary " id="updateUser">Update</button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>

    </div>
</div>




