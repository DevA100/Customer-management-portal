{
  //"Logging": {
  //  "LogLevel": {
  //    "Default": "Information",
  //    "Microsoft": "Warning",
  //    "Microsoft.Hosting.Lifetime": "Information"
  //  }
  //},
  "ConnectionStrings": {
    "DefaultConnection": "Your_DB_Server"
  },
  "AdminRights": {
    "admins": "Admin_user"
  },
  "AllowedHosts": "*",
  "connectionUrls": {
    "IPBase": "https://example.com",
    "GetAccountDetails": "your_endpoint",
    "SendIncidentSMStoCustomer": "your_endpoint",
    "SendIncidentEmailtoCustomer": "your_endpoint"

  },
  "Serilog": {
    "LevelSwitches": { "$controlSwitch": "Debug" },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      },
      "ControlledBy": "$controlSwitch"
    },
    "Enrich": [ "fm", "fm", "fm", "fm" ],
    "WriteTo": [
      {
        "Name": "Logger",
        "Args": {
          "serverUrl": "",
          "apiKey": "",
          "controlLevelSwitch": "$controlSwitch"
        }
      },
      {
        "Name": "File",
        "Args": {
          
          "path": "c:\\urpath\\log.txt",
          "outputTemplate": "{Timestamp:o} {Message}{NewLine:1}{Exception:1}",
          "fileSizeLimitBytes": 10000,
          "retainedFileCountLimit": 7,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  }
}  

